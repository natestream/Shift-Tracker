{
  "name": "shift-tracker",
  "version": "v1.2.0",
  "description": "Shift time tracker tray app",
  "main": "main.js",
  "license": "UNLICENSED",
  "author": {
    "name": "Nate Stream",
    "email": "nathanstream203@gmail.com"
    },
  "scripts": {
    "start": "electron .",
    "build": "dotenv cross-env electron-builder",
    "publish": "dotenv cross-env electron-builder -- --publish always"
  },
  "build": {
    "appId": "com.nate.shift-tracker",
    "icon": "assets/icon",
    "productName": "Shift Tracker",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "**/*",
      "!CLAUDE.md",
      "!README.md",
      "!.claude/**",
      "!generate-ico.js",
      "!generate-icons.js",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "nathanstream203",
      "repo": "Shift-Tracker"
    }
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jimp": "^1.6.1",
    "playwright-core": "^1.60.0",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
